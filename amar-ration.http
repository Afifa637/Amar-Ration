@baseUrl = http://localhost:5000/api

### 1) Admin Login (seeded)
# @name adminLogin
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "identifier": "admin@amar-ration.local",
  "password": "admin123",
  "userType": "Admin"
}

### 2) Distributor Login (seeded)
# @name distributorLogin
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "identifier": "distributor@amar-ration.local",
  "password": "dist123",
  "userType": "Distributor"
}

### 3) FieldUser Login (seeded)
# @name fieldLogin
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "identifier": "field@amar-ration.local",
  "password": "field123",
  "userType": "FieldUser"
}

### 4) Who am I (Admin)
GET {{baseUrl}}/auth/me
Authorization: Bearer {{adminLogin.response.body.data.token}}

### 5) Admin Summary
GET {{baseUrl}}/admin/summary
Authorization: Bearer {{adminLogin.response.body.data.token}}

### 6) Admin Distributors
GET {{baseUrl}}/admin/distributors
Authorization: Bearer {{adminLogin.response.body.data.token}}

### 7) Distributor Dashboard
GET {{baseUrl}}/distributor/dashboard
Authorization: Bearer {{distributorLogin.response.body.data.token}}

### 8) Distributor Monitoring Summary
GET {{baseUrl}}/monitoring/summary
Authorization: Bearer {{distributorLogin.response.body.data.token}}

### 9) Notifications (unread)
GET {{baseUrl}}/notifications?status=Unread
Authorization: Bearer {{distributorLogin.response.body.data.token}}

### 10) Field session status
GET {{baseUrl}}/field/session-status
Authorization: Bearer {{fieldLogin.response.body.data.token}}
