float extractJsonNumber(const String &body, const String &key, float fallback) {
  int start = body.indexOf(key);
  if (start < 0) return fallback;
  start += key.length();
  while (start < (int)body.length() && (body[start] == ' ' || body[start] == '"' || body[start] == ':')) start++;
  int end = start;
  while (end < (int)body.length()) {
    char c = body[end];
    if ((c >= '0' && c <= '9') || c == '.' || c == '-' || c == '+') end++;
    else break;
  }
  if (end <= start) return fallback;
  return body.substring(start, end).toFloat();
}

bool syncTargetsFromBackend() {
  if (backend_base_url.length() == 0 || backend_api_key.length() == 0) {
    last_sync_http_code = -1;
    last_sync_message = "Missing backend URL or API key";
    return false;
  }

  if (WiFi.status() != WL_CONNECTED) {
    last_sync_http_code = -2;
    last_sync_message = "WiFi not connected (device likely in AP mode)";
    return false;
  }

  HTTPClient http;
  String url = backend_base_url;
  if (!url.endsWith("/")) url += "/";
  url += "iot/product-targets";

  http.begin(url);
  http.addHeader("x-iot-api-key", backend_api_key);
  int httpCode = http.GET();
  last_sync_http_code = httpCode;
  if (httpCode != HTTP_CODE_OK) {
    String errBody = http.getString();
    last_sync_message = "HTTP " + String(httpCode) + " from backend: " + errBody;
    http.end();
    return false;
  }

  String payload = http.getString();
  http.end();

  target_p1 = extractJsonNumber(payload, "\"p1Kg\":", target_p1);
  target_p2 = extractJsonNumber(payload, "\"p2Kg\":", target_p2);
  target_p3 = extractJsonNumber(payload, "\"p3Kg\":", target_p3);
  last_sync_message = "Sync OK: P1=" + String(target_p1, 2) + ", P2=" + String(target_p2, 2) + ", P3=" + String(target_p3, 2);
  return true;
}

