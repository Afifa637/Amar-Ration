// ================== সার্ভার হ্যান্ডলার ==================
void handleRoot() { server.send(200, "text/html", index_html); }

void handleTargets() {
  if(server.hasArg("u")) current_user = server.arg("u");
  if(server.hasArg("i")) current_id = server.arg("i");
  server.send(200, "text/plain", "Customer details updated. Product targets are synced from backend.");
}

void handleCurrentTargets() {
  String payload = "{";
  payload += "\"p1Kg\":" + String(target_p1, 2) + ",";
  payload += "\"p2Kg\":" + String(target_p2, 2) + ",";
  payload += "\"p3Kg\":" + String(target_p3, 2) + "}";
  server.send(200, "application/json", payload);
}

void handleGetTable() {
  if(saved_data_html == "") {
      server.send(200, "text/html", "<p style='color:#ffc107;'>No records found yet.</p>");
  } else {
      String table = "<table><tr><th>ID</th><th>Name</th><th>Item</th><th>Wt(g)</th><th>Status</th></tr>";
      table += saved_data_html;
      table += "</table>";
      server.send(200, "text/html", table);
  }
}

void handleZero() { scale.tare(); server.send(200, "text/plain", "Scale Zeroed Successfully!"); }

void handleCalibrate() {
  if(server.hasArg("w")) {
    float known_weight = server.arg("w").toFloat();
    if(known_weight > 0) {
      long reading = scale.get_value(10); 
      cal_factor = reading / known_weight; 
      scale.set_scale(cal_factor);
      server.send(200, "text/plain", "Calibration Successful!");
    }
  }
}

void handleTolerance() {
  if(server.hasArg("g")) {
    tolerance_g = max(0.0f, server.arg("g").toFloat());
    server.send(200, "text/plain", "Tolerance Updated!");
  }
}

void handleScanWifi() {
  // In AP fallback, keep hotspot alive while enabling station scan.
  WiFi.mode(WIFI_AP_STA);
  int n = WiFi.scanNetworks(false, true);
  String options = "<option value=''>Select Network</option>";
  if (n <= 0) {
    options += "<option value=''>No 2.4GHz WiFi found</option>";
  } else {
    for (int i = 0; i < n; ++i) {
      String ssid = WiFi.SSID(i);
      if (ssid.length() == 0) ssid = "(hidden)";
      options += "<option value='" + ssid + "'>" + ssid + "</option>";
    }
  }
  WiFi.scanDelete();
  server.send(200, "text/html", options);
}

void handleSaveWifi() {
  if(server.hasArg("s") && server.hasArg("p")) {
    preferences.begin("wifi_creds", false);
    preferences.putString("ssid", server.arg("s"));
    preferences.putString("pass", server.arg("p"));
    preferences.end();
    server.send(200, "text/plain", "WiFi Saved! ESP is Restarting...");
    delay(1000); ESP.restart();
  }
}

void handleSaveBackend() {
  if(server.hasArg("url") && server.hasArg("key")) {
    backend_base_url = server.arg("url");
    backend_api_key = server.arg("key");

    preferences.begin("backend_cfg", false);
    preferences.putString("url", backend_base_url);
    preferences.putString("key", backend_api_key);
    preferences.end();

    server.send(200, "text/plain", "Backend config saved!");
  } else {
    server.send(400, "text/plain", "Backend URL and key are required!");
  }
}

void handleSyncTargets() {
  if (syncTargetsFromBackend()) {
    server.send(200, "text/plain", last_sync_message);
  } else {
    String msg = "Target sync failed. " + last_sync_message;
    msg += " | Device IP: ";
    msg += (WiFi.status() == WL_CONNECTED) ? WiFi.localIP().toString() : "AP mode";
    server.send(500, "text/plain", msg);
  }
}

// ================== SETUP ==================
void setup() {
  Serial.begin(115200);
  lcd.init(); lcd.backlight();
  lcd.setCursor(0, 0); lcd.print("Smart Ration");

  pinMode(BTN_P1, INPUT_PULLUP); pinMode(BTN_P2, INPUT_PULLUP); pinMode(BTN_P3, INPUT_PULLUP);
  pinMode(BTN_RESET, INPUT_PULLUP); pinMode(BTN_TARE, INPUT_PULLUP);

  scale.begin(LOADCELL_DOUT_PIN, LOADCELL_SCK_PIN);
  scale.set_scale(cal_factor);
  scale.tare(); 

  // WiFi Connection Logic (AP Mode Fallback)
  preferences.begin("wifi_creds", true);
  String saved_ssid = preferences.getString("ssid", "");
  String saved_pass = preferences.getString("pass", "");
  preferences.end();

  preferences.begin("backend_cfg", true);
  backend_base_url = preferences.getString("url", "");
  backend_api_key = preferences.getString("key", "");
  preferences.end();

  lcd.setCursor(0, 1); lcd.print("Connecting...   ");
  
  if (saved_ssid != "") {
      WiFi.mode(WIFI_STA);
      WiFi.begin(saved_ssid.c_str(), saved_pass.c_str());
      int retries = 0;
      while (WiFi.status() != WL_CONNECTED && retries < 15) { delay(500); Serial.print("."); retries++; }
  }

  lcd.clear();
  if (WiFi.status() == WL_CONNECTED) {
      lcd.setCursor(0, 0); lcd.print("WiFi Connected!");
      lcd.setCursor(0, 1); lcd.print("IP:"); lcd.print(WiFi.localIP());
  } else {
      // যদি কানেক্ট না হয়, তাহলে নিজস্ব হটস্পট (AP Mode) চালু করবে
      WiFi.mode(WIFI_AP_STA);
      WiFi.softAP("Smart Ration", "12345678");
      lcd.setCursor(0, 0); lcd.print("AP Mode Active!");
      lcd.setCursor(0, 1); lcd.print("IP:192.168.4.1 ");
  }
  
  // রাউটিং
  server.on("/", handleRoot);
  server.on("/set_targets", handleTargets);
  server.on("/current_targets", handleCurrentTargets);
  server.on("/get_table", handleGetTable);
  server.on("/zero", handleZero);
  server.on("/calibrate", handleCalibrate);
  server.on("/set_tol", handleTolerance);
  server.on("/scan_wifi", handleScanWifi);
  server.on("/save_wifi", handleSaveWifi);
  server.on("/save_backend", handleSaveBackend);
  server.on("/sync_targets", handleSyncTargets);

  // OTA আপডেট হ্যান্ডলার
  server.on("/update", HTTP_POST, []() {
    server.sendHeader("Connection", "close");
    server.send(200, "text/plain", (Update.hasError()) ? "Update Failed" : "Update Success! Restarting...");
    delay(1000); ESP.restart();
  }, []() {
    HTTPUpload& upload = server.upload();
    if (upload.status == UPLOAD_FILE_START) { if (!Update.begin(UPDATE_SIZE_UNKNOWN)) Update.printError(Serial); } 
    else if (upload.status == UPLOAD_FILE_WRITE) { if (Update.write(upload.buf, upload.currentSize) != upload.currentSize) Update.printError(Serial); } 
    else if (upload.status == UPLOAD_FILE_END) { Update.end(true); }
  });

  server.begin();
  delay(3000); lcd.clear();

  if (WiFi.status() == WL_CONNECTED && backend_base_url.length() > 0 && backend_api_key.length() > 0) {
    syncTargetsFromBackend();
  }
}

// ================== MAIN LOOP ==================
void loop() {
  server.handleClient(); 
  float currentWeightKg = scale.get_units(5);
  float currentWeightG = currentWeightKg * 1000.0;

  if (digitalRead(BTN_TARE) == LOW) {
    if (currentWeightG > 50.0) { 
      lcd.clear(); lcd.print("Tare Failed!"); lcd.setCursor(0, 1); lcd.print("Weight > 50g"); delay(2000);
    } else {
      scale.tare(); lcd.clear(); lcd.print("Tared Success!"); delay(1000);
    }
  }

  if (digitalRead(BTN_RESET) == LOW) {
    selected_product = 0; lcd.clear(); lcd.print("System Reset"); delay(1000); lcd.clear();
  }

  // --- P1, P2, P3 Buttons (Save Logic) ---
  int btn_pressed = 0;
  if (digitalRead(BTN_P1) == LOW) btn_pressed = 1;
  else if (digitalRead(BTN_P2) == LOW) btn_pressed = 2;
  else if (digitalRead(BTN_P3) == LOW) btn_pressed = 3;

  if (btn_pressed > 0) {
    if (selected_product == btn_pressed) { 
      float targetKg = (btn_pressed==1) ? target_p1 : (btn_pressed==2) ? target_p2 : target_p3;
      float targetG = targetKg * 1000.0;
      float diffG = currentWeightG - targetG;
        
      if (abs(diffG) <= tolerance_g) { 
            lcd.clear(); lcd.print("Data Saved!"); 
            
            // ডাটাবেসে (টেবিলে) সেভ হচ্ছে
            String p_name = (btn_pressed == 1) ? "Rice" : (btn_pressed == 2) ? "Lentil" : "Onion";
        saved_data_html += "<tr><td>" + current_id + "</td><td>" + current_user + "</td><td>" + p_name + "</td><td>" + String(currentWeightG, 1) + "</td><td style='color:#00ff00;'>Success</td></tr>";

            delay(1500); selected_product = 0; 
        } else {
            lcd.clear(); lcd.print("Fix Weight First"); delay(1500);
        }
    } else {
        selected_product = btn_pressed; 
        lcd.clear(); lcd.print("Selected: P"); lcd.print(btn_pressed); delay(1000);
    }
    lcd.clear();
  }

  // --- DISPLAY LOGIC ---
  if(digitalRead(BTN_TARE) == HIGH && digitalRead(BTN_RESET) == HIGH && btn_pressed == 0) {
      lcd.setCursor(0, 0);
      float targetKg = 0.0;
      float targetG = 0.0;

      if (selected_product == 1) { targetKg = target_p1; targetG = targetKg * 1000.0; lcd.print("P1:"); lcd.print(targetG, 0); lcd.print("g   "); }
      else if (selected_product == 2) { targetKg = target_p2; targetG = targetKg * 1000.0; lcd.print("P2:"); lcd.print(targetG, 0); lcd.print("g   "); }
      else if (selected_product == 3) { targetKg = target_p3; targetG = targetKg * 1000.0; lcd.print("P3:"); lcd.print(targetG, 0); lcd.print("g   "); }
      else { lcd.print("Select Product  "); }
      
      lcd.setCursor(0, 1); lcd.print(currentWeightG, 0); lcd.print("g      ");

      if (selected_product > 0) {
        float diffG = currentWeightG - targetG;
          lcd.setCursor(10, 1);
        if (diffG > tolerance_g) { lcd.print("OVER "); } 
        else if (diffG < -tolerance_g) { lcd.print("UNDER"); } 
          else { lcd.print("OK!  "); }
      } else {
          lcd.setCursor(10, 1); lcd.print("      "); 
      }
      delay(200); 
  }
}