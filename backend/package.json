{
  "name": "amar-ration-backend-mongo",
  "version": "1.0.0",
  "type": "commonjs",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "seed": "node src/seed/seed.js",
    "indexes": "node src/setup/ensure-indexes.js",
    "db:verify": "node src/setup/verify-collections.js",
    "db:create-enterprise": "node src/setup/create-missing-enterprise-collections.js",
    "db:prune": "node src/setup/prune-extra-collections.js",
    "cron:test": "node -e \"const {startCronJobs}=require('./src/jobs/cron.jobs');startCronJobs()\"",
    "sms:flush": "node -e \"require('./src/services/sms.service').processSmsQueue().then(()=>process.exit())\"",
    "admin:setup": "node src/setup/create-admin.js"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.15.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "speakeasy": "^2.0.0",
    "uuid": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "nodemon": "^3.1.4"
  }
}
