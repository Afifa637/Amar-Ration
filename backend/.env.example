PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?appName=Cluster0

JWT_SECRET=change_me_super_secret
JWT_EXPIRES_IN=2h
NID_ENCRYPTION_KEY=change_me_nid_encryption_key_32_chars_min
IOT_API_KEY=change_me_iot_key

# SMTP mail configuration (required for credential emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=mailer@example.com
SMTP_PASS=change_me
MAIL_FROM="Amar Ration <no-reply@example.com>"

# Distributor portal login URL used in credential emails
DISTRIBUTOR_LOGIN_URL=http://localhost:5173/login/distributor

# Production: comma-separated list of allowed frontend origins
# ALLOWED_ORIGINS=https://admin.amarration.gov.bd,https://dist.amarration.gov.bd
# Development: leave empty or set to localhost
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Admin Setup (only used once during setup — delete after running create-admin.js)
# ADMIN_EMAIL=admin@yourorg.gov.bd
# ADMIN_PHONE=01XXXXXXXXX
# ADMIN_PASSWORD=YourSecure12CharPassword!
# ADMIN_NAME=Central Admin
